---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="About">
  <div class="about-header">
    <h1>FUNDACIONES</h1>
    <p class="subtitle">LO QUE HACE QUE ASTRO FUNCIONE.</p>
  </div>

  <div class="skills-grid">
    <div class="skill-item">ISLAND ARCHITECTURE</div>
    <div class="skill-item">CERO JS BUNDLE</div>
    <div class="skill-item">STATIC SITE GENERATION</div>
    <div class="skill-item">SERVER-SIDE RENDERING</div>
    <div class="skill-item">AGNOSTIC COMPONENTS</div>
    <div class="skill-item">VIEW TRANSITIONS</div>
  </div>

  <a href="/" class="back-link">VOLVER AL INICIO</a>
</MainLayout>

<style>
  .about-header {
    border-bottom: var(--border-thick);
    padding-bottom: 2rem;
    margin-bottom: 4rem;
  }

  .subtitle {
    font-size: clamp(1.5rem, 4vw, 3rem);
    font-weight: bold;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .skill-item {
    border: var(--border-thick);
    padding: 2rem;
    font-size: 2.5rem;
    font-weight: 900;
    text-transform: uppercase;
    text-align: center;
    background-color: var(--text-color);
    color: var(--bg-color);
    transition: all 0.2s ease;
  }

  .skill-item:hover {
    background-color: var(--bg-color);
    color: var(--text-color);
    transform: translate(-10px, -10px);
    box-shadow: 10px 10px 0px var(--text-color);
  }

  .back-link {
    display: block;
    text-align: center;
    font-size: 3rem;
    padding: 2rem;
    border: var(--border-thick);
    text-transform: uppercase;
  }
</style>
